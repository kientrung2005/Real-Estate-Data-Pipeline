# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=real_estate_db
DB_USER=postgres
DB_PASSWORD=your_password

# MongoDB Configuration
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASS=your_mongodb_password

# Airflow Configuration
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__DAGS_FOLDER=./dags
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Web Scraping
CHOTTOT_BASE_URL=https://www.nhatot.com/ban-nha-ha-noi
BATDONGSAN_BASE_URL=https://batdongsan.com/ban-nha-ha-noi
REQUEST_TIMEOUT=10
RETRY_ATTEMPTS=3

# Data Settings
CRAWL_SCHEDULE=0 2 * * *  # 2 AM daily
DATA_RETENTION_DAYS=365
