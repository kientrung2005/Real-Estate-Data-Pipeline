# =================================================================
# REAL ESTATE DATA PIPELINE - ENVIRONMENT CONFIGURATION TEMPLATE
# =================================================================
# Hướng dẫn: 
# 1. Copy file này thành file .env
# 2. Thay đổi các giá trị bên dưới cho phù hợp với môi trường của bạn.
# =================================================================

# ===== POSTGRESQL CONFIGURATION =====
# Nếu chạy Local (Windows): dùng localhost
# Nếu chạy Docker: dùng tên service (thường là postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=real_estate_db
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password

# ===== MONGODB CONFIGURATION =====
# Nếu chạy Local (Windows): dùng localhost
# Nếu chạy Docker: dùng tên service (thường là mongodb)
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=your_mongo_user
MONGO_PASS=your_mongo_password

# ===== WEB SCRAPING CONFIGURATION =====
CHOTTOT_URL=https://www.nhatot.com/mua-ban-bat-dong-san-ha-noi
BATDONGSAN_URL=https://batdongsan.com.vn/ban-nha-dat-ha-noi
REQUEST_TIMEOUT=10
RETRY_ATTEMPTS=3

# ===== DATA & SCHEDULING =====
CRAWL_SCHEDULE=0 2 * * *
DATA_RETENTION_DAYS=365

# ===== AIRFLOW CONFIGURATION (OPTIONAL) =====
# Thư mục lưu log và profile trình duyệt trong Airflow
AIRFLOW_UID=50000
